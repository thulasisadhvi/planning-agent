# .env.example
# LLM Configuration
LLM_PROVIDER="ollama" # or "anthropic"
OLLAMA_BASE_URL="http://ollama:11434"
OLLAMA_MODEL="llama3.1:8b"
ANTHROPIC_API_KEY="your_anthropic_api_key_if_using"

# Application Settings
MCP_SERVER_URL="http://mock-mcp-server:8000" # URL for the mock university catalog
LOG_LEVEL="INFO"
AGENT_MAX_STEPS=10 # Step limit for the agent loop